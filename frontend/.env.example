# ==============================================================================
# Frontend (Next.js) — frontend/.env.local
# Salin file ini menjadi frontend/.env.local lalu isi nilainya.
# JANGAN commit file .env.local ke git!
# ==============================================================================

# ---- PUBLIC (aman di-expose ke browser) ----

# Contract address setelah deploy ke Sepolia
# Isi setelah menjalankan: npx hardhat ignition deploy ...
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_AFTER_DEPLOY

# RPC URL untuk read-only call (boleh public)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Base URL aplikasi untuk generate link QR code
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- SECRET (hanya di server — JANGAN pakai prefix NEXT_PUBLIC_!) ----

# Private key admin untuk write transactions via API route
# Harus sama dengan SEPOLIA_PRIVATE_KEY di root .env
ADMIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URL untuk server-side wallet client
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# ---- Cloudflare R2 (server-side only — JANGAN pakai prefix NEXT_PUBLIC_!) ----
# Account ID dari dashboard Cloudflare R2
R2_ACCOUNT_ID=YOUR_CF_ACCOUNT_ID
# R2 API Token → Access Key ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
# R2 API Token → Secret Access Key
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
# Nama bucket R2
R2_BUCKET_NAME=sertifikat
